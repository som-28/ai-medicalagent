# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/
/.pnp
.pnp.*
# Yarn (kept for compatibility if ever used)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-lock.yaml

# Package manager caches
npm-cache/
yarn-cache/
pnpm-store/

# Testing / Coverage
coverage/
playwright-report/
test-results/
.nyc_output/
.eslintcache

# Next.js build output
.next/
out/

# Production build (if manually created)
build/
dist/

# Misc certs / keys
*.pem
*.key
*.crt
*.cert

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files (keep example only)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Clerk (avoid committing secret configuration caches)
.clerk/

# Local database artifacts
*.db
*.sqlite
*.sqlite3
*.dump
*.sql

# Temporary migration helpers (keep the actual migration SQL files committed)
migrate.ts
migrate-emergency.ts

# Logs
logs/
*.log
*.log.*

# IDE / Editor
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS generated files
Thumbs.db
.DS_Store

# Backup / temp files
*.bak
*.backup
*.orig
*.tmp

# Generated type metadata
*.tsbuildinfo
next-env.d.ts

# Drizzle cache (keep migrations folder if present)
drizzle/meta/*
